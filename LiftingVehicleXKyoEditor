                            hum:EquipTool(bpTool)
                        end
                    end
                end
                
                if char and char:FindFirstChild("Punch") then
                    char.Punch:Activate()
                end
                
                task.wait(0.1)
            end
        end)
    else
        stopNoclip()
        Fluent:Notify({
            Title = "Farm Status",
            Content = "Farm and Auto Punch deactivated.",
            Duration = 3
        })
    end
end)

