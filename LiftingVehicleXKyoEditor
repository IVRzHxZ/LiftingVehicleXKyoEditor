-- Permanent Anti-Gravity Anchor Tracker
local globalFloatVelocity = nil

local function applyFloatLock(rootPart)
    if not globalFloatVelocity or globalFloatVelocity.Parent ~= rootPart then
        if globalFloatVelocity then globalFloatVelocity:Destroy() end
        globalFloatVelocity = Instance.new("BodyVelocity")
        globalFloatVelocity.Velocity = Vector3.zero
        globalFloatVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        globalFloatVelocity.Parent = rootPart
    end
end

local function removeFloatLock()
    if globalFloatVelocity then
        globalFloatVelocity:Destroy()
        globalFloatVelocity = nil
    end
end

-- Safe Noclip Engine
local noclipConnection = nil
local function startNoclip()
    if noclipConnection then noclipConnection:Disconnect() end
    noclipConnection = RunService.Stepped:Connect(function()
        if getgenv().AutoParadiseFarm and LocalPlayer.Character then
            for _, part in ipairs(LocalPlayer.Character:GetChildren()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
        end
    end)
end

local function stopNoclip()
    if noclipConnection then
        noclipConnection:Disconnect()
        noclipConnection = nil
    end
    removeFloatLock()
end

local function getAllParadiseChests()
    local chests = {}
    pcall(function()
        for _, obj in pairs(Workspace:GetDescendants()) do
            local targetPart = nil
            if obj:IsA("BasePart") and string.find(obj.Name, CHEST_NAME) then
                targetPart = obj
            elseif obj:IsA("Model") and string.find(obj.Name, CHEST_NAME) then
                targetPart = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
            end
            if targetPart and targetPart:IsDescendantOf(Workspace) then
                table.insert(chests, targetPart)
            end
        end
    end)
    return chests
end

-- Pure Loop TP - Position Fixed 0.1 Studs Above Chest (Small Offset)
local function loopTeleportToChest(targetPart)
    local character = LocalPlayer.Character
    if not character then return false end
    
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid or humanoid.Health <= 0 then return false end

    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return false end
    if not targetPart or not targetPart:IsDescendantOf(Workspace) then return false end

    local targetCFrame = targetPart.CFrame * CFrame.new(0, 2, 0) 
    
    rootPart.AssemblyLinearVelocity = Vector3.zero
    rootPart.AssemblyAngularVelocity = Vector3.zero
    rootPart.CFrame = targetCFrame

    applyFloatLock(rootPart)

    task.wait(0.2) 

    if not humanoid or humanoid.Health <= 0 then return false end

    local prompt = targetPart:FindFirstChildWhichIsA("ProximityPrompt") or targetPart.Parent:FindFirstChildWhichIsA("ProximityPrompt")
    if prompt then
        local fired = false
        if fireproximityprompt then
            fireproximityprompt(prompt)
            fired = true
        elseif firepromptprint then
            firepromptprint(prompt)
            fired = true
        end

        if fired then
            TotalChestsFarmed = TotalChestsFarmed + 1
            CoinParagraph:SetTitle("Collected Coins")
            CoinParagraph:SetText("Chests Farmed: " .. tostring(TotalChestsFarmed))
            return true
        end
    end
    return false
end

-- Combined Farm & Auto Punch Event Listener
FarmToggle:OnChanged(function(Value)
    getgenv().AutoParadiseFarm = Value

    if Value then
        startNoclip()
        Fluent:Notify({
            Title = "Farm Status",
            Content = "Coins Farm & Auto Punch Enabled!",
            Duration = 3
        })

        -- Thread 1: Coins Farm Loop
        task.spawn(function()
            while getgenv().AutoParadiseFarm do
                local char = LocalPlayer.Character
                local hum = char and char:FindFirstChildOfClass("Humanoid")

                if hum and hum.Health > 0 and char:FindFirstChild("HumanoidRootPart") then
                    local activeChests = getAllParadiseChests()

                    if #activeChests > 0 then
                        for i, chestPart in ipairs(activeChests) do
                            if not getgenv().AutoParadiseFarm then break end

                            local currentHum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
                            if currentHum and currentHum.Health > 0 then
                                if chestPart and chestPart:IsDescendantOf(Workspace) then
                                    local successfullyFarmed = loopTeleportToChest(chestPart)

                                    if successfullyFarmed then
                                        -- Dito kinukuha ang live value mula sa slider habang tumatakbo ang loop
                                        local currentDelay = Options.ChestDelaySlider and Options.ChestDelaySlider.Value or 1.80
                                        task.wait(currentDelay)
                                    else
                                        task.wait(90) 
                                    end
                                end
                            else
                                break 
                            end
                        end
                    else
                        task.wait(0.5) 
                    end
                else
                    task.wait(1)
                end
                task.wait(0.05)
            end
            removeFloatLock()
        end)

        -- Thread 2: Auto Punch Loop
        task.spawn(function()
            while getgenv().AutoParadiseFarm do
                local char = LocalPlayer.Character
                local backpack = LocalPlayer:FindFirstChild("Backpack")
                local tool = char and char:FindFirstChild("Punch")
                
