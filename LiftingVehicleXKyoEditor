-- Instant Teleport Loop Engine
local function startInstantTPEngine()
    if tpConnection then tpConnection:Disconnect() end
    
    tpConnection = runService.Heartbeat:Connect(function()
        if not _G.AutoFarm or not player.Character then return end
        local root = player.Character:FindFirstChild("HumanoidRootPart")
        if not root or not currentTargetCFrame then return end
        
        root.AssemblyLinearVelocity = Vector3.zero
        root.AssemblyAngularVelocity = Vector3.zero
        root.CFrame = currentTargetCFrame
    end)
end

-- Anti-Stop Farming Loop Engine (Deep-Copy Snapshot Protection)
task.spawn(function()
    while true do
        if _G.AutoFarm and gemSpawns and mineRemote then
            local farmedAny = false
            
            -- GUMAWA NG SNAPSHOT: Kopyahin ang mga zones para hindi mag-error kapag binago sa dropdown
            local currentZonesSnapshot = {}
            for zoneName, isSelected in pairs(_G.SelectedZones) do
                currentZonesSnapshot[zoneName] = isSelected
            end
            
            -- Ito ang babasahin ng loop para ligtas sa kahit anong pagbabago
            for zoneName, isSelected in pairs(currentZonesSnapshot) do
                if not _G.AutoFarm then break end
                if not isSelected then continue end
                
                -- Double check kung tinanggal na habang papunta sa zone na ito
                if not _G.SelectedZones[zoneName] then continue end
                
                local folderName = zoneMapping[zoneName]
                local zoneFolder = gemSpawns:FindFirstChild(folderName)
                
                if zoneFolder then
                    local gems = zoneFolder:GetChildren()
                    
                    for _, gem in ipairs(gems) do
                        if not _G.AutoFarm then break end
                        if not _G.SelectedZones[zoneName] then break end -- Huminto agad kapag inalis ang zone na ito
                        
                        if gem:IsA("BasePart") and gem.Parent == zoneFolder then
                            farmedAny = true
                            currentTargetCFrame = gem.CFrame * CFrame.new(0, 3, 0)
                            
                            pcall(function()
                                mineRemote:FireServer(gem)
                            end)
                            
                            if _G.LoopDelay > 0 then
                                task.wait(_G.LoopDelay)
                            else
                                runService.Heartbeat:Wait()
                            end
                        end
                    end
                end
            end
            if not farmedAny then task.wait(0.1) end
        else
            task.wait(0.1)
        end
    end
end)

