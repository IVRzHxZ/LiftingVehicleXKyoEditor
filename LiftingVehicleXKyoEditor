-- 7. Smooth Long-Press Dragging Implementation (Includes Smart Lock feature)
local function MakeDraggableOpenUi(topbar, obj)
    local dragging, dragInput, dragStart, startPos = false, nil, nil, nil
    local holdingDrag, holdToken = false, 0
    obj:SetAttribute("Locked", false)
    
    local function Update(input)
        if obj:GetAttribute("Locked") then return end
        local delta = input.Position - dragStart
        local targetPosition = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        
        -- Applied smooth tweening from Script 1 for a polished feel
        local tweenInfo = TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        TweenService:Create(obj, tweenInfo, {Position = targetPosition}):Play()
    end
    
    local function ToggleLock()
        local newState = not obj:GetAttribute("Locked")
        obj:SetAttribute("Locked", newState)
        if Fluent and Fluent.Notify then
            Fluent:Notify({
                Title = newState and "Button Locked" or "Button Unlocked", 
                Content = newState and "Locked in place." or "Can now be moved.", 
                Duration = 2
            })
        end
    end
    
    topbar.InputBegan:Connect(function(input)
        if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then return end
        dragging = not obj:GetAttribute("Locked")
        holdingDrag = true
        dragStart = input.Position
        startPos = obj.Position
        holdToken = holdToken + 1
        local token = holdToken
        
        -- Long press for 1 second toggles lock/unlock status
        task.delay(1.0, function() 
            if holdingDrag and token == holdToken then 
                ToggleLock() 
            end 
        end)
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then 
                dragging = false 
                holdingDrag = false 
            end
        end)
    end)
    
    topbar.InputChanged:Connect(function(input)
        if not dragStart then return end
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            if (input.Position - dragStart).Magnitude > 6 then 
                holdingDrag = false 
            end
            dragInput = input
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then 
            Update(input) 
        end
    end)
end

MakeDraggableOpenUi(CustomButton, CustomButton)

-- 8. Audio and Speed Animation Logic
local function playSound(soundId)
    local sound = Instance.new("Sound")
    sound.SoundId = "rbxassetid://" .. soundId
    sound.Parent = SoundService
    sound:Play()
    sound.Ended:Connect(function() sound:Destroy() end)
end

local isAnimating = false
local function smoothSpeed(target, dur)
    local start = rotSpeed
    local steps = 30
    for i = 1, steps do
        rotSpeed = start + (target - start) * (i / steps)
        task.wait(dur / steps)
    end
    rotSpeed = target
end

-- 9. Click Connection Execution Block
CustomButton.MouseButton1Click:Connect(function()
    -- Audio playback
    local sounds = {"7127123605", "137566474343039", "438666542"}
    playSound(sounds[math.random(#sounds)])
    
    -- Toggles Fluent UI Window state
    pcall(function()
        Window:Minimize()
    end)
    
    -- Dynamic spin cycle animation
    if not isAnimating then
        isAnimating = true
        task.spawn(function()
            smoothSpeed(360, 0.4)
            task.wait(0.5)
            smoothSpeed(180, 0.4)
            task.wait(0.3)
            smoothSpeed(90, 0.4)
            isAnimating = false
        end)
    end
end)

