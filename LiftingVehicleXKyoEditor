    if antiLagEnabled then
        -- 1. Optimize existing assets in the world
        for _, v in pairs(workspace:GetDescendants()) do
            optimizePart(v)
        end
        
        -- 2. Downgrade lighting and render quality
        lighting.GlobalShadows = false
        lighting.FogEnd = 9e9
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
        
        library:CreateNotification("Anti-Lag", "FPS Boost Activated! Visuals minimized.", 4)
    else
        -- 3. Restore original visuals perfectly
        for part, props in pairs(originalMaterials) do
            if part and part.Parent then
                for prop, val in pairs(props) do
                    part[prop] = val
                end
            end
        end
        table.clear(originalMaterials)
        
        lighting.GlobalShadows = true
        settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic
        
        library:CreateNotification("Anti-Lag", "Visuals restored to normal.", 4)
    end
end)

