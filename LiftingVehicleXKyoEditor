-- [FORMATTERS] Time and Multi-Shorthand Numbers
local function formatTime(seconds)
    local hours = math.floor(seconds / 3600)
    local minutes = math.floor((seconds % 3600) / 60)
    local secs = math.floor(seconds % 60)
    return string.format("%02d:%02d:%02d", hours, minutes, secs)
end

local function formatNumber(val)
    local num = tonumber(val) or 0
    local suffixes = {"", "K", "M", "B", "T", "Qa", "Qi", "Sx"}
    local index = 1
    
    while math.abs(num) >= 1000 and index < #suffixes do
        num = num / 1000
        index = index + 1
    end
    
    if index > 1 then
        return string.format("%.1f%s", num, suffixes[index])
    end
    return string.format("%d", num)
end

-- [DEEP SEARCH ENGINE] Scan Values, Folders, Attributes, and UIs
local function findStatValue(playerObj, names)
    if not playerObj then return 0 end
    
    local targets = {}
    for _, name in ipairs(names) do
        table.insert(targets, name)
        table.insert(targets, string.lower(name))
        table.insert(targets, string.upper(name))
    end

    -- Layer 1: Global Descendant Sweep (leaderstats, custom data folders)
    local success, descendants = pcall(function() return playerObj:GetDescendants() end)
    if success and descendants then
        for _, child in ipairs(descendants) do
            if child:IsA("ValueBase") then
                for _, targetName in ipairs(targets) do
                    if child.Name == targetName then
                        return tonumber(child.Value) or 0
                    end
                end
            end
        end
    end
    
    -- Layer 2: Core Attribute Scraper
    for _, targetName in ipairs(targets) do
        local attr = playerObj:GetAttribute(targetName)
        if attr and tonumber(attr) then 
            return tonumber(attr) 
        end
    end
    
    -- Layer 3: Screen UI Scraper Fallback
    if playerObj == LocalPlayer then
        local pGui = LocalPlayer:FindFirstChild("PlayerGui")
        if pGui then
            for _, name in ipairs(names) do
                for _, gui in ipairs(pGui:GetChildren()) do
                    if gui:IsA("ScreenGui") and gui.Enabled then
                        local found = gui:FindFirstChild(name .. "Text", true) 
                            or gui:FindFirstChild(name .. "Label", true) 
                            or gui:FindFirstChild(name, true)
                            
                        if found and found:IsA("TextLabel") then
                            local cleanNum = string.gsub(found.Text, "[%,%s%a💪🔥🏋️⚡📈💀⚔️]", "")
                            if tonumber(cleanNum) then return tonumber(cleanNum) end
                        end
                    end
                end
            end
        end
    end
    return 0
end

